PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string example:
# mongodb+srv://<username>:<password>@<cluster>.mongodb.net/civicresourceai?retryWrites=true&w=majority
MONGODB_URI=

# Set a strong random secret for JWT signing
JWT_SECRET=

# URL of the AI engine service
AI_ENGINE_URL=http://localhost:8000

# Optional: allow seeding against default DB names such as test/admin/local.
# Keep this false/empty in normal usage.
SEED_ALLOW_DEFAULT_DB=false
